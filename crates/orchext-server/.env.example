# Copy to .env and fill in before running `docker compose up`.
# The values below are safe defaults for local development only —
# do not use them in production.

# Password used by both the postgres container and the server's
# DATABASE_URL. Changing this requires wiping the postgres-data volume
# unless you also run ALTER USER on the existing database.
ORCHEXT_POSTGRES_PASSWORD=orchext-dev-password

# Set to 0 for local HTTP development. Production HTTPS deployments
# must keep this at 1 (the default) so the browser refuses to send
# session cookies over a downgrade.
ORCHEXT_SECURE_COOKIES=0

# Comma-separated origins allowed to make credentialed cross-origin
# requests. Leave empty (the default) to mount no CORS layer —
# same-origin still works, cross-origin browsers get blocked. Set
# only if you serve the web UI from a different origin than the API:
#   ORCHEXT_CORS_ALLOW_ORIGINS=https://orchext.example.com
ORCHEXT_CORS_ALLOW_ORIGINS=
